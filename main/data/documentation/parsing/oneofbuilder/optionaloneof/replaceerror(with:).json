:" ","type":"text"},{"text":"for building up complex parsers that cannot fail.","type":"text"}]}],"kind":"content"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/co.pointfree.URLRouting\/documentation\/Parsing","doc:\/\/co.pointfree.URLRouting\/documentation\/Parsing\/OneOfBuilder","doc:\/\/co.pointfree.URLRouting\/documentation\/Parsing\/OneOfBuilder\/OptionalOneOf","doc:\/\/co.pointfree.URLRouting\/documentation\/Parsing\/OneOfBuilder\/OptionalOneOf\/Parser-Implementations"]]},"references":{"doc://co.pointfree.URLRouting/documentation/Parsing/OneOfBuilder/OptionalOneOf/Parser-Implementations":{"title":"Parser Implementations","url":"\/documentation\/parsing\/oneofbuilder\/optionaloneof\/parser-implementations","role":"collectionGroup","abstract":[],"type":"topic","kind":"article","identifier":"doc:\/\/co.pointfree.URLRouting\/documentation\/Parsing\/OneOfBuilder\/OptionalOneOf\/Parser-Implementations"},"doc://co.pointfree.URLRouting/documentation/Parsing":{"kind":"symbol","type":"topic","title":"Parsing","abstract":[],"identifier":"doc:\/\/co.pointfree.URLRouting\/documentation\/Parsing","role":"collection","url":"\/documentation\/parsing"},"doc://co.pointfree.URLRouting/documentation/Parsing/Parsers":{"url":"\/documentation\/parsing\/parsers","role":"symbol","type":"topic","title":"Parsers","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Parsers"}],"navigatorTitle":[{"kind":"identifier","text":"Parsers"}],"abstract":[{"type":"text","text":"A namespace for types that serve as parsers."}],"identifier":"doc:\/\/co.pointfree.URLRouting\/documentation\/Parsing\/Parsers","kind":"symbol"},"doc://co.pointfree.URLRouting/documentation/Parsing/Parsers/ReplaceError":{"role":"symbol","type":"topic","url":"\/documentation\/parsing\/parsers\/replaceerror","title":"Parsers.ReplaceError","kind":"symbol","identifier":"doc:\/\/co.pointfree.URLRouting\/documentation\/Parsing\/Parsers\/ReplaceError","abstract":[{"text":"A parser